# Default User and Group IDs for container process permissions on host bind mounts
# Set UID and GID to your current host user's IDs to avoid file ownership issues
# On Linux/macOS, run `id -u` and `id -g` to check your values:
# export UID=$(id -u)
# export GID=$(id -g)
UID=1000
GID=1000

# Path to local Docker daemon Unix domain socket
# On native Linux setups (including Fedora Workstation), default socket location is /var/run/docker.sock
# For rootless Docker setups, set to $XDG_RUNTIME_DIR/docker.sock or custom socket path
DOCKER_SOCKET=/var/run/docker.sock
